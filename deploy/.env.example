# Copy to deploy/.env and fill in. NEVER commit the real .env (it is gitignored).
# DATABASE_URL must point at the compose `db` service.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/recourse
ENVIRONMENT=production
CORS_ORIGINS=

# --- AI/ML API (Blake, Morgan, Sam) ---
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o

# --- Featherless (Alex) ---
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=NousResearch/Hermes-2-Pro-Llama-3-8B

# --- Band agents ---
BAND_REST_URL=https://app.band.ai
BAND_WS_URL=wss://app.band.ai
BAND_USER_API_KEY=
BAND_COORDINATOR_AGENT_ID=
BAND_COORDINATOR_API_KEY=
BAND_COORDINATOR_HANDLE=
BAND_BLAKE_AGENT_ID=
BAND_BLAKE_API_KEY=
BAND_BLAKE_HANDLE=
BAND_MORGAN_AGENT_ID=
BAND_MORGAN_API_KEY=
BAND_MORGAN_HANDLE=
BAND_ALEX_AGENT_ID=
BAND_ALEX_API_KEY=
BAND_ALEX_HANDLE=
BAND_SAM_AGENT_ID=
BAND_SAM_API_KEY=
BAND_SAM_HANDLE=

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
