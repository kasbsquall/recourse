# ============================================================
# RECOURSE — Environment variables
# Copy this file to `.env` and fill in the real values.
# NEVER commit the real `.env` (it is gitignored).
# ============================================================

# --- Database (Intervención 2: Supabase) ---
# Local dev (docker-compose): postgresql+asyncpg://postgres:postgres@localhost:5433/recourse
# (host port 5433 avoids clashing with a local PostgreSQL on 5432)
# Supabase prod: grab the connection string from Project Settings > Database.
# IMPORTANT: SQLAlchemy async needs the `+asyncpg` driver suffix.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/recourse

# --- Band agents (Intervención 1: band.ai dashboard) ---
# Band issues ONE API key per agent (not a single global key).
# Platform URLs (SDK defaults) + the user/account key for the Human API.
BAND_REST_URL=https://app.band.ai
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_USER_API_KEY=   # personal/account key, starts with band_u_ (backend creates rooms + reads transcripts)

BAND_BLAKE_AGENT_ID=
BAND_BLAKE_API_KEY=
BAND_BLAKE_HANDLE=

BAND_MORGAN_AGENT_ID=
BAND_MORGAN_API_KEY=
BAND_MORGAN_HANDLE=

BAND_ALEX_AGENT_ID=
BAND_ALEX_API_KEY=
BAND_ALEX_HANDLE=

BAND_SAM_AGENT_ID=
BAND_SAM_API_KEY=
BAND_SAM_HANDLE=

# Coordinator (5th agent) — intakes the claim, creates the room, posts the case file.
BAND_COORDINATOR_AGENT_ID=
BAND_COORDINATOR_API_KEY=
BAND_COORDINATOR_HANDLE=

# --- AI/ML API (aimlapi.com) — partner prize, Blake + Morgan ---
# Redeem the hackathon coupon on aimlapi.com, then create an API key in your
# account dashboard (Settings > API Keys). The coupon adds credits; it is NOT the key.
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o

# --- Featherless AI (partner prize, Alex) ---
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=NousResearch/Hermes-2-Pro-Llama-3-8B

# --- App config ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
